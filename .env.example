# APP_URL: Public base URL for QR, overlay, wallet, and review links.
APP_URL="http://localhost:3000"

# PERSISTENCE_DRIVER: Required before production business routes can mutate state.
# Current allowed development value is "memory".
PERSISTENCE_DRIVER="memory"

# DATABASE_URL: PostgreSQL connection used by Drizzle migrations and production persistence.
DATABASE_URL="postgres://sway:sway@localhost:5432/sway_tips"

# STRIPE_SECRET_KEY: Server-side Stripe API key. Use test keys locally and live keys only in production secrets.
STRIPE_SECRET_KEY=""

# STRIPE_WEBHOOK_SECRET: Signing secret for /api/payment/webhook. Must match the Stripe endpoint mode.
STRIPE_WEBHOOK_SECRET=""

# SWAY_STRIPE_CONNECT_COUNTRY: Default ISO country for new Stripe Accounts v2 recipient accounts.
SWAY_STRIPE_CONNECT_COUNTRY="US"

# SWAY_APP_BASE_URL: Canonical base URL for performer magic-link emails.
SWAY_APP_BASE_URL="http://localhost:3000"

# SWAY_EMAIL_PROVIDER: Production-only transactional email provider.
SWAY_EMAIL_PROVIDER="resend"

# SWAY_EMAIL_API_KEY: Production-only API key for the configured transactional email provider.
SWAY_EMAIL_API_KEY=""

# SWAY_EMAIL_FROM: Production-only sender address for performer sign-in links.
SWAY_EMAIL_FROM="Sway <performers@sway.tips>"

# SWAY_PERFORMER_LOGIN_RATE_LIMIT_MAX: Max performer login link requests per IP+email bucket.
SWAY_PERFORMER_LOGIN_RATE_LIMIT_MAX="3"

# SWAY_PERFORMER_LOGIN_RATE_LIMIT_WINDOW_MS: Window for performer login request rate limiting.
SWAY_PERFORMER_LOGIN_RATE_LIMIT_WINDOW_MS="600000"

# SWAY_PERFORMER_SIGNUP_RATE_LIMIT_MAX: Max performer signup requests per IP bucket.
SWAY_PERFORMER_SIGNUP_RATE_LIMIT_MAX="3"

# SWAY_PERFORMER_SIGNUP_RATE_LIMIT_WINDOW_MS: Window for performer signup request rate limiting.
SWAY_PERFORMER_SIGNUP_RATE_LIMIT_WINDOW_MS="900000"

# SWAY_PERFORMER_PASSWORD_LOGIN_RATE_LIMIT_MAX: Max failed email+password login attempts per IP+account bucket.
SWAY_PERFORMER_PASSWORD_LOGIN_RATE_LIMIT_MAX="5"

# SWAY_PERFORMER_PASSWORD_LOGIN_RATE_LIMIT_WINDOW_MS: Window for failed email+password login rate limiting.
SWAY_PERFORMER_PASSWORD_LOGIN_RATE_LIMIT_WINDOW_MS="900000"

# MUSIC_CATALOG_PROVIDER: Required before production music search can return catalog data.
MUSIC_CATALOG_PROVIDER=""
