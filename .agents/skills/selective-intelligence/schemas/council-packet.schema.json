{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/Platynum-Standard/Selective-Intelligence/main/skills/selective-intelligence/schemas/council-packet.schema.json",
  "title": "Selective Intelligence Guided Council Packet",
  "description": "Portable structural schema for Guided Council cases, role packets, role responses, alignment records, and resume packets. scripts/council.py is authoritative for cross-document bindings and semantic controls.",
  "oneOf": [
    { "$ref": "#/$defs/councilCase" },
    { "$ref": "#/$defs/workerPacket" },
    { "$ref": "#/$defs/workerResponse" },
    { "$ref": "#/$defs/objectorPacket" },
    { "$ref": "#/$defs/objectorResponse" },
    { "$ref": "#/$defs/alignmentPacket" },
    { "$ref": "#/$defs/alignmentRecord" },
    { "$ref": "#/$defs/resumePacket" }
  ],
  "$defs": {
    "id": {
      "type": "string",
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]{0,127}$"
    },
    "digest": {
      "type": "string",
      "pattern": "^[a-f0-9]{64}$"
    },
    "timestamp": {
      "type": "string",
      "format": "date-time"
    },
    "date": {
      "type": "string",
      "format": "date"
    },
    "nonEmptyString": {
      "type": "string",
      "minLength": 1
    },
    "uniqueStrings": {
      "type": "array",
      "items": { "$ref": "#/$defs/nonEmptyString" },
      "uniqueItems": true
    },
    "nonEmptyUniqueStrings": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/nonEmptyString" },
      "uniqueItems": true
    },
    "parent": {
      "type": "object",
      "required": ["packet_id", "packet_type", "digest"],
      "properties": {
        "packet_id": { "$ref": "#/$defs/id" },
        "packet_type": {
          "enum": [
            "council_case",
            "worker_packet",
            "worker_response",
            "objector_packet",
            "objector_response",
            "alignment_packet",
            "alignment_record",
            "resume_packet"
          ]
        },
        "digest": { "$ref": "#/$defs/digest" }
      },
      "additionalProperties": false
    },
    "startPackBinding": {
      "type": ["object", "null"],
      "required": [
        "project_id",
        "release_id",
        "validator_version",
        "control_digest",
        "semantic_digest",
        "bound_at"
      ],
      "properties": {
        "project_id": { "$ref": "#/$defs/nonEmptyString" },
        "release_id": { "$ref": "#/$defs/nonEmptyString" },
        "validator_version": { "$ref": "#/$defs/nonEmptyString" },
        "control_digest": { "$ref": "#/$defs/digest" },
        "semantic_digest": { "$ref": "#/$defs/digest" },
        "bound_at": { "$ref": "#/$defs/timestamp" }
      },
      "additionalProperties": false
    },
    "intentLock": {
      "type": "object",
      "required": [
        "outcome",
        "reason",
        "primary_user",
        "job",
        "non_negotiables",
        "prohibitions",
        "tradeoff_rules",
        "included_scope",
        "excluded_scope",
        "material_open_decisions",
        "confidence",
        "source_precedence",
        "success_criteria",
        "authority_owner",
        "permission_boundaries",
        "permission_policy_id",
        "permission_policy_digest"
      ],
      "properties": {
        "outcome": { "$ref": "#/$defs/nonEmptyString" },
        "reason": { "$ref": "#/$defs/nonEmptyString" },
        "primary_user": { "$ref": "#/$defs/nonEmptyString" },
        "job": { "$ref": "#/$defs/nonEmptyString" },
        "non_negotiables": { "$ref": "#/$defs/nonEmptyUniqueStrings" },
        "prohibitions": { "$ref": "#/$defs/uniqueStrings" },
        "tradeoff_rules": { "$ref": "#/$defs/nonEmptyUniqueStrings" },
        "included_scope": { "$ref": "#/$defs/nonEmptyUniqueStrings" },
        "excluded_scope": { "$ref": "#/$defs/uniqueStrings" },
        "material_open_decisions": { "$ref": "#/$defs/uniqueStrings" },
        "confidence": { "enum": ["locked", "supported", "provisional", "conflicted", "unknown"] },
        "source_precedence": { "$ref": "#/$defs/nonEmptyUniqueStrings" },
        "success_criteria": { "$ref": "#/$defs/nonEmptyUniqueStrings" },
        "authority_owner": { "$ref": "#/$defs/nonEmptyString" },
        "permission_boundaries": { "$ref": "#/$defs/nonEmptyUniqueStrings" },
        "permission_policy_id": { "$ref": "#/$defs/id" },
        "permission_policy_digest": { "$ref": "#/$defs/digest" }
      },
      "allOf": [
        {
          "if": {
            "properties": { "confidence": { "enum": ["locked", "supported"] } },
            "required": ["confidence"]
          },
          "then": {
            "properties": { "material_open_decisions": { "maxItems": 0 } }
          }
        }
      ],
      "additionalProperties": false
    },
    "projectBoundary": {
      "type": "object",
      "required": [
        "project_id",
        "adapter_id",
        "adapter_version",
        "adapter_digest",
        "allowed_destinations",
        "allowed_data_classes"
      ],
      "properties": {
        "project_id": { "$ref": "#/$defs/nonEmptyString" },
        "adapter_id": { "$ref": "#/$defs/nonEmptyString" },
        "adapter_version": { "$ref": "#/$defs/nonEmptyString" },
        "adapter_digest": { "$ref": "#/$defs/digest" },
        "allowed_destinations": { "$ref": "#/$defs/nonEmptyUniqueStrings" },
        "allowed_data_classes": { "$ref": "#/$defs/nonEmptyUniqueStrings" }
      },
      "additionalProperties": false
    },
    "roleRun": {
      "type": "object",
      "required": [
        "run_id",
        "role",
        "provider",
        "model",
        "surface",
        "context_id",
        "billing_pool_id",
        "allowed_data_classes",
        "started_at",
        "completed_at"
      ],
      "properties": {
        "run_id": { "$ref": "#/$defs/id" },
        "role": { "enum": ["orchestrator", "worker", "objector", "aligner", "reserve"] },
        "provider": { "$ref": "#/$defs/nonEmptyString" },
        "model": { "$ref": "#/$defs/nonEmptyString" },
        "surface": { "$ref": "#/$defs/nonEmptyString" },
        "context_id": { "$ref": "#/$defs/nonEmptyString" },
        "billing_pool_id": { "$ref": "#/$defs/nonEmptyString" },
        "allowed_data_classes": { "$ref": "#/$defs/uniqueStrings" },
        "started_at": { "$ref": "#/$defs/timestamp" },
        "completed_at": {
          "oneOf": [
            { "$ref": "#/$defs/timestamp" },
            { "type": "null" }
          ]
        },
        "parent_run_id": {
          "oneOf": [
            { "$ref": "#/$defs/id" },
            { "type": "null" }
          ]
        }
      },
      "additionalProperties": false
    },
    "approvalReceipt": {
      "type": "object",
      "required": [
        "approval_id",
        "action",
        "destination",
        "project_id",
        "data_classes",
        "approved_by",
        "approved_at",
        "expires_at",
        "max_minor_units",
        "billing_pool_id",
        "price_evidence_ids"
      ],
      "properties": {
        "approval_id": { "$ref": "#/$defs/id" },
        "action": { "$ref": "#/$defs/actionName" },
        "destination": { "$ref": "#/$defs/nonEmptyString" },
        "project_id": { "$ref": "#/$defs/nonEmptyString" },
        "data_classes": { "$ref": "#/$defs/uniqueStrings" },
        "approved_by": { "$ref": "#/$defs/nonEmptyString" },
        "approved_at": { "$ref": "#/$defs/timestamp" },
        "expires_at": {
          "oneOf": [
            { "$ref": "#/$defs/timestamp" },
            { "type": "null" }
          ]
        },
        "max_minor_units": {
          "type": ["integer", "null"],
          "minimum": 0
        },
        "billing_pool_id": {
          "oneOf": [
            { "$ref": "#/$defs/id" },
            { "type": "null" }
          ]
        },
        "price_evidence_ids": { "$ref": "#/$defs/uniqueStrings" }
      },
      "allOf": [
        {
          "if": { "properties": { "action": { "const": "spend" } }, "required": ["action"] },
          "then": {
            "properties": {
              "max_minor_units": { "type": "integer", "minimum": 0 },
              "billing_pool_id": { "$ref": "#/$defs/id" },
              "price_evidence_ids": { "$ref": "#/$defs/nonEmptyUniqueStrings" }
            }
          },
          "else": {
            "properties": {
              "max_minor_units": { "type": "null" },
              "billing_pool_id": { "type": "null" },
              "price_evidence_ids": { "maxItems": 0 }
            }
          }
        }
      ],
      "additionalProperties": false
    },
    "permissionRule": {
      "type": "object",
      "required": ["rule_id", "action", "effect", "destination", "project_id", "data_classes"],
      "properties": {
        "rule_id": { "$ref": "#/$defs/id" },
        "action": { "$ref": "#/$defs/actionName" },
        "effect": { "enum": ["allow", "approval_required", "deny"] },
        "destination": { "$ref": "#/$defs/nonEmptyString" },
        "project_id": { "$ref": "#/$defs/nonEmptyString" },
        "data_classes": { "$ref": "#/$defs/uniqueStrings" }
      },
      "allOf": [
        {
          "if": { "properties": { "effect": { "const": "allow" } }, "required": ["effect"] },
          "then": { "properties": { "action": { "enum": ["read_source", "read_repository"] } } }
        }
      ],
      "additionalProperties": false
    },
    "permissions": {
      "type": "object",
      "required": ["policy_id", "policy_digest", "default", "rules", "approval_receipts"],
      "properties": {
        "policy_id": { "$ref": "#/$defs/id" },
        "policy_digest": { "$ref": "#/$defs/digest" },
        "default": { "const": "deny" },
        "rules": {
          "type": "array",
          "items": { "$ref": "#/$defs/permissionRule" }
        },
        "approval_receipts": {
          "type": "array",
          "items": { "$ref": "#/$defs/approvalReceipt" }
        }
      },
      "additionalProperties": false
    },
    "actionName": {
      "enum": [
        "read_source",
        "read_repository",
        "write_file",
        "modify_drive",
        "send_email",
        "push_code",
        "open_pr",
        "merge_pr",
        "delete",
        "publish",
        "spend",
        "change_permissions",
        "export_sensitive_data"
      ]
    },
    "action": {
      "type": "object",
      "required": [
        "action_id",
        "action",
        "destination",
        "project_id",
        "data_classes",
        "approval_id",
        "amount_minor_units",
        "billing_pool_id",
        "price_evidence_ids"
      ],
      "properties": {
        "action_id": { "$ref": "#/$defs/id" },
        "action": { "$ref": "#/$defs/actionName" },
        "destination": { "$ref": "#/$defs/nonEmptyString" },
        "project_id": { "$ref": "#/$defs/nonEmptyString" },
        "data_classes": { "$ref": "#/$defs/uniqueStrings" },
        "approval_id": {
          "oneOf": [
            { "$ref": "#/$defs/id" },
            { "type": "null" }
          ]
        },
        "amount_minor_units": {
          "type": ["integer", "null"],
          "minimum": 0
        },
        "billing_pool_id": {
          "oneOf": [
            { "$ref": "#/$defs/id" },
            { "type": "null" }
          ]
        },
        "price_evidence_ids": { "$ref": "#/$defs/uniqueStrings" }
      },
      "allOf": [
        {
          "if": { "properties": { "action": { "const": "spend" } }, "required": ["action"] },
          "then": {
            "properties": {
              "approval_id": { "$ref": "#/$defs/id" },
              "amount_minor_units": { "type": "integer", "minimum": 0 },
              "billing_pool_id": { "$ref": "#/$defs/id" },
              "price_evidence_ids": { "$ref": "#/$defs/nonEmptyUniqueStrings" }
            }
          },
          "else": {
            "properties": {
              "amount_minor_units": { "type": "null" },
              "billing_pool_id": { "type": "null" },
              "price_evidence_ids": { "maxItems": 0 }
            }
          }
        }
      ],
      "additionalProperties": false
    },
    "budgetPool": {
      "type": "object",
      "required": [
        "pool_id",
        "kind",
        "enabled",
        "hard_limit_minor_units",
        "spent_minor_units",
        "overage_allowed"
      ],
      "properties": {
        "pool_id": { "$ref": "#/$defs/id" },
        "kind": { "enum": ["fixed", "metered", "credits"] },
        "enabled": { "type": "boolean" },
        "hard_limit_minor_units": { "type": "integer", "minimum": 0 },
        "spent_minor_units": { "type": "integer", "minimum": 0 },
        "overage_allowed": { "const": false }
      },
      "allOf": [
        {
          "if": {
            "properties": { "kind": { "const": "metered" }, "enabled": { "const": true } },
            "required": ["kind", "enabled"]
          },
          "then": { "properties": { "hard_limit_minor_units": { "type": "integer", "minimum": 1 } } }
        }
      ],
      "additionalProperties": false
    },
    "priceEvidence": {
      "type": "object",
      "required": [
        "evidence_id",
        "service",
        "amount_minor_units",
        "currency",
        "region",
        "source_url",
        "observed_on",
        "expires_on",
        "revalidate_on"
      ],
      "properties": {
        "evidence_id": { "$ref": "#/$defs/id" },
        "service": { "$ref": "#/$defs/nonEmptyString" },
        "amount_minor_units": { "type": "integer", "minimum": 0 },
        "currency": { "type": "string", "pattern": "^[A-Z]{3}$" },
        "region": { "$ref": "#/$defs/nonEmptyString" },
        "source_url": { "type": "string", "format": "uri" },
        "observed_on": { "$ref": "#/$defs/date" },
        "expires_on": {
          "oneOf": [
            { "$ref": "#/$defs/date" },
            { "type": "null" }
          ]
        },
        "revalidate_on": {
          "oneOf": [
            { "$ref": "#/$defs/nonEmptyString" },
            { "type": "null" }
          ]
        }
      },
      "anyOf": [
        { "properties": { "expires_on": { "$ref": "#/$defs/date" } }, "required": ["expires_on"] },
        { "properties": { "revalidate_on": { "$ref": "#/$defs/nonEmptyString" } }, "required": ["revalidate_on"] }
      ],
      "additionalProperties": false
    },
    "budget": {
      "type": "object",
      "required": [
        "currency",
        "shared_fixed_minor_units",
        "per_project_fixed_minor_units",
        "metered_planning_minor_units",
        "expected_increment_minor_units",
        "expected_total_minor_units",
        "pools",
        "price_evidence"
      ],
      "properties": {
        "currency": { "type": "string", "pattern": "^[A-Z]{3}$" },
        "shared_fixed_minor_units": { "type": "integer", "minimum": 0 },
        "per_project_fixed_minor_units": { "type": "integer", "minimum": 0 },
        "metered_planning_minor_units": { "type": "integer", "minimum": 0 },
        "expected_increment_minor_units": { "type": "integer", "minimum": 0 },
        "expected_total_minor_units": { "type": "integer", "minimum": 0 },
        "pools": { "type": "array", "items": { "$ref": "#/$defs/budgetPool" } },
        "price_evidence": { "type": "array", "items": { "$ref": "#/$defs/priceEvidence" } }
      },
      "additionalProperties": false
    },
    "capability": {
      "type": "object",
      "required": ["capability_id", "disposition", "canonical_owner", "evidence_refs"],
      "properties": {
        "capability_id": { "$ref": "#/$defs/id" },
        "disposition": { "enum": ["reuse", "extend", "extract", "consolidate", "create", "remove"] },
        "canonical_owner": { "$ref": "#/$defs/nonEmptyString" },
        "evidence_refs": { "$ref": "#/$defs/nonEmptyUniqueStrings" }
      },
      "additionalProperties": false
    },
    "source": {
      "type": "object",
      "required": [
        "source_id",
        "provider",
        "immutable_id",
        "title",
        "source_type",
        "project_id",
        "authority",
        "sensitivity",
        "data_classes",
        "version",
        "modified_at",
        "validated_at",
        "summary"
      ],
      "properties": {
        "source_id": { "$ref": "#/$defs/id" },
        "provider": { "$ref": "#/$defs/nonEmptyString" },
        "immutable_id": { "$ref": "#/$defs/nonEmptyString" },
        "title": { "$ref": "#/$defs/nonEmptyString" },
        "source_type": { "$ref": "#/$defs/nonEmptyString" },
        "project_id": { "$ref": "#/$defs/nonEmptyString" },
        "authority": { "enum": ["authoritative", "supporting", "draft", "unknown"] },
        "sensitivity": { "enum": ["public", "internal", "confidential", "restricted"] },
        "data_classes": { "$ref": "#/$defs/nonEmptyUniqueStrings" },
        "version": { "$ref": "#/$defs/nonEmptyString" },
        "modified_at": { "$ref": "#/$defs/timestamp" },
        "validated_at": { "$ref": "#/$defs/timestamp" },
        "summary": { "$ref": "#/$defs/nonEmptyString" }
      },
      "additionalProperties": false
    },
    "evidence": {
      "type": "object",
      "required": [
        "evidence_id",
        "source_id",
        "locator",
        "summary",
        "classification",
        "observed_at",
        "content_digest"
      ],
      "properties": {
        "evidence_id": { "$ref": "#/$defs/id" },
        "source_id": { "$ref": "#/$defs/id" },
        "locator": { "$ref": "#/$defs/nonEmptyString" },
        "summary": { "$ref": "#/$defs/nonEmptyString" },
        "classification": { "enum": ["confirmed", "inferred", "created", "unknown", "conflicted"] },
        "observed_at": { "$ref": "#/$defs/timestamp" },
        "content_digest": { "$ref": "#/$defs/digest" }
      },
      "additionalProperties": false
    },
    "task": {
      "type": "object",
      "required": [
        "task_id",
        "exact_task",
        "output_contract",
        "success_criteria",
        "prohibitions",
        "source_ids",
        "capability_ids",
        "requested_actions",
        "required_proof_ids"
      ],
      "properties": {
        "task_id": { "$ref": "#/$defs/id" },
        "exact_task": { "$ref": "#/$defs/nonEmptyString" },
        "output_contract": { "$ref": "#/$defs/nonEmptyString" },
        "success_criteria": { "$ref": "#/$defs/nonEmptyUniqueStrings" },
        "prohibitions": { "$ref": "#/$defs/uniqueStrings" },
        "source_ids": { "$ref": "#/$defs/nonEmptyUniqueStrings" },
        "capability_ids": { "$ref": "#/$defs/nonEmptyUniqueStrings" },
        "requested_actions": { "type": "array", "items": { "$ref": "#/$defs/action" } },
        "required_proof_ids": { "$ref": "#/$defs/nonEmptyUniqueStrings" }
      },
      "additionalProperties": false
    },
    "proof": {
      "type": "object",
      "required": [
        "proof_id",
        "status",
        "claim",
        "evidence_refs",
        "revision",
        "observed_at",
        "supersedes"
      ],
      "properties": {
        "proof_id": { "$ref": "#/$defs/id" },
        "status": { "enum": ["valid", "invalidated"] },
        "claim": { "$ref": "#/$defs/nonEmptyString" },
        "evidence_refs": { "$ref": "#/$defs/nonEmptyUniqueStrings" },
        "revision": { "$ref": "#/$defs/nonEmptyString" },
        "observed_at": { "$ref": "#/$defs/timestamp" },
        "supersedes": {
          "oneOf": [
            { "$ref": "#/$defs/id" },
            { "type": "null" }
          ]
        }
      },
      "additionalProperties": false
    },
    "externalAction": {
      "type": "object",
      "required": [
        "action_id",
        "kind",
        "destination",
        "status",
        "idempotency_key",
        "receipt_ref",
        "retry_safe"
      ],
      "properties": {
        "action_id": { "$ref": "#/$defs/id" },
        "kind": { "$ref": "#/$defs/nonEmptyString" },
        "destination": { "$ref": "#/$defs/nonEmptyString" },
        "status": { "enum": ["not_started", "attempted", "confirmed", "failed", "compensated"] },
        "idempotency_key": { "$ref": "#/$defs/nonEmptyString" },
        "receipt_ref": {
          "oneOf": [
            { "$ref": "#/$defs/nonEmptyString" },
            { "type": "null" }
          ]
        },
        "retry_safe": { "type": "boolean" }
      },
      "additionalProperties": false
    },
    "repositoryState": {
      "type": ["object", "null"],
      "required": ["repository_id", "branch", "commit", "dirty"],
      "properties": {
        "repository_id": { "$ref": "#/$defs/nonEmptyString" },
        "branch": { "$ref": "#/$defs/nonEmptyString" },
        "commit": { "$ref": "#/$defs/nonEmptyString" },
        "dirty": { "type": "boolean" }
      },
      "additionalProperties": false
    },
    "continuity": {
      "type": "object",
      "required": [
        "current_state_summary",
        "repository",
        "uncommitted_changes",
        "migrations",
        "external_actions",
        "completed_steps",
        "next_safe_action",
        "checkpointed_at"
      ],
      "properties": {
        "current_state_summary": { "$ref": "#/$defs/nonEmptyString" },
        "repository": { "$ref": "#/$defs/repositoryState" },
        "uncommitted_changes": { "$ref": "#/$defs/uniqueStrings" },
        "migrations": { "$ref": "#/$defs/uniqueStrings" },
        "external_actions": { "type": "array", "items": { "$ref": "#/$defs/externalAction" } },
        "completed_steps": { "$ref": "#/$defs/uniqueStrings" },
        "next_safe_action": { "$ref": "#/$defs/nonEmptyString" },
        "checkpointed_at": { "$ref": "#/$defs/timestamp" }
      },
      "additionalProperties": false
    },
    "finding": {
      "type": "object",
      "required": [
        "finding_id",
        "target_kind",
        "target_ref",
        "category",
        "statement",
        "evidence_refs",
        "counterexample_or_failed_test",
        "recommended_correction",
        "severity",
        "material"
      ],
      "properties": {
        "finding_id": { "$ref": "#/$defs/id" },
        "target_kind": { "enum": ["claim", "artifact", "permission", "scope", "capability", "proof", "continuity"] },
        "target_ref": { "$ref": "#/$defs/nonEmptyString" },
        "category": {
          "enum": [
            "unsupported_claim",
            "missing_evidence",
            "unsafe_permission",
            "scope_drift",
            "unnecessary_complexity",
            "duplication",
            "failure_case",
            "provenance",
            "continuity"
          ]
        },
        "statement": { "$ref": "#/$defs/nonEmptyString" },
        "evidence_refs": { "$ref": "#/$defs/nonEmptyUniqueStrings" },
        "counterexample_or_failed_test": { "$ref": "#/$defs/nonEmptyString" },
        "recommended_correction": { "$ref": "#/$defs/nonEmptyString" },
        "severity": { "enum": ["advisory", "material", "blocking"] },
        "material": { "type": "boolean" }
      },
      "additionalProperties": false
    },
    "disposition": {
      "type": "object",
      "required": ["finding_id", "resolution", "evidence_refs", "rationale", "correction_id", "closed"],
      "properties": {
        "finding_id": { "$ref": "#/$defs/id" },
        "resolution": { "enum": ["sustained", "rejected", "unresolved", "superseded"] },
        "evidence_refs": { "$ref": "#/$defs/nonEmptyUniqueStrings" },
        "rationale": { "$ref": "#/$defs/nonEmptyString" },
        "correction_id": {
          "oneOf": [
            { "$ref": "#/$defs/id" },
            { "type": "null" }
          ]
        },
        "closed": { "type": "boolean" }
      },
      "allOf": [
        {
          "if": { "properties": { "resolution": { "const": "unresolved" } }, "required": ["resolution"] },
          "then": {
            "properties": { "closed": { "const": false }, "correction_id": { "type": "null" } }
          }
        },
        {
          "if": {
            "properties": { "resolution": { "enum": ["rejected", "superseded"] } },
            "required": ["resolution"]
          },
          "then": { "properties": { "correction_id": { "type": "null" } } }
        }
      ],
      "additionalProperties": false
    },
